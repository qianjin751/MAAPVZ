{
    "interface_version": 2,
    "name": "MaaPVZ",
    "description": "这是超级冷门的游戏居然有人做脚本的pvzmaa。",
    "contact": "QQ群: 669689256",
    "license": "MIT",
    "github": "https://github.com/Maa-Assistant-PVZ-The-best/MAAPVZ",
    "icon": ".\\resource\\logo.ico",
    "mirrorchyan_rid": "MaaPVZ",
    "mirrorchyan_multiplatform": true,
    "agent": {
        "child_exec": "../.venv/Scripts/python.exe",
        "child_args": [
            "-u",
            "../agent/main.py"
        ],
        "identifier": "3be2c931-9c0d-4d69-9ebd-eed2263e06fd",
        "debug_session": "Agent 调试"
    },
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "icon": ".\\resource\\logo.ico",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "PVZ_2_国服通用",
            "path": [
                "./resource"
            ],
            "option": [
                "渠道服"
            ]
        }
    ],
    "import": [
        "./resource/task/plants_explore_debris.json",
        "./resource/task/fragment_challenge.json",
        "./resource/task/get_gold_coins.json",
        "./resource/task/Start_game.json",
        "./resource/task/Secret_realm.json",
        "./resource/task/Endless.json",
        "./resource/task/pair_duel.json",
        "./resource/task/mini_tools.json",
        "./resource/task/test.json"
    ],
    "task": [
        {
            "name": "开始登录",
            "entry": "选择渠道服",
            "option": [
                "存档覆盖进度",
                "重复启动时黑屏请打开"
            ],
            "resource": [
                "PVZ_2_国服通用"
            ],
            "default_check": true,
            "description": "打开模拟器后开始"
        },
        {
            "name": "签到",
            "entry": "签到_前置检查",
            "default_check": true,
            "description": "进行每日签到任务"
        },
        {
            "name": "植物探险",
            "entry": "植物探险_前置检查",
            "default_check": true,
            "option": [
                "双倍碎片（需要免广告卡）",
                "海盗/埃及",
                "西部/功夫",
                "未来/黑暗",
                "海滩/冰河",
                "天空/失落",
                "摇滚/恐龙",
                "摩登/蒸汽",
                "平安/复兴",
                "海底世界"
            ],
            "description": "先领取奖励，再进行探险"
        },
        {
            "name": "潘妮秘宝（测试）",
            "default_check": true,
            "entry": "潘妮密保_前置检查"
        },
        {
            "name": "免广告卡",
            "entry": "有免广告卡_前置检查",
            "option": [
                "每日免费五十钻",
                "潘妮秘宝",
                "超z钥匙"
            ],
            "default_check": true,
            "description": "需要拥有免广告卡"
        },
        {
            "name": "碎片挑战（测试）",
            "entry": "碎片挑战_前置检查",
            "description": "建议给仙人掌加点攻击，传奇巨人有概率会输",
            "option": [
                "选择植物碎片",
                "使用免广告卡",
                "巨人危机配置",
                "邪恶入侵配置"
                // "暴走雪人配置"
            ]
        },
        {
            "name": "旅行原木（测试）",
            "entry": "旅行原木_前置检查",
            "default_check": true
        },
        {
            "name": "刷胜场/金币（测试）",
            "entry": "埃及第一关刷金币_前置检查",
            "description": "不要给仙人掌带超级装扮",
            "option": [
                "刷金币模式选择"
            ]
        },
        {
            "name": "幸运宝藏（测试）",
            "description": "仅自动领取，不会向你汇报获得什么东西",
            "entry": "幸运宝藏_前置检查"
        },
        {
            "name": "时空秘境（测试）",
            "option": [
                "模式选择"
            ],
            "entry": "时空秘境_前置检查",
            "default_check": false
        },
        {
            "name": "无尽挑战（测试）",
            "entry": "无尽挑战_前置检查",
            "option": [
                "当期无尽模式"
            ]
        },
        {
            "name": "戴夫杯（测试）",
            "entry": "Dai_Enter",
            "default_check": false,
            "description": "在匹配界面开脚本"
        },
        {
            "name": "无尽挂机脚本框架",
            "entry": "Frame_Wj_Entry",
            "description": "脚本只负责点开始游戏,继续挑战,加速,补给等操作,可以摆自己设计的挂机阵,脚本默认开启划飞弹和点波,布好阵了在开脚本,不然种不了植物(详细的功能介绍见公告:设置->关于我们->显示公告)",
            "option": [
                "小关是否喂豆",
                "全局是否抛花",
                "fw_boss关是否需要喂豆",
                "是否需要补植物",
                "小关是否加速",
                "fw_boss关是否加速",
                "fw_boss_补给是否优先选神器",
                "fw_boss_是否开相机神器",
                "是否魔甘收尾(牢玩家专属)"
            ]
        },
        {
            "name": "双人对决（已禁用）",
            "entry": "双人对决_前置检查",
            "resource": [
                "PVZ_2_国服通用"
            ],
            "option": [
                "配置模式",
                "匹配模式",
                "到达特定回合释放特定的僵尸",
                "僵尸强化buff",
                "放置3阶5阶植物",
                "额外弹窗直接关闭"
            ],
            "description": "擅自开启造成的后果概不负责"
        },
        {
            "name": "小工具",
            "entry": "mini_tools",
            "option": [
                "选择工具"
            ]
        },
        {
            "name": "日志清理",
            "entry": "cleanup_maafw_bak_logs",
            "option": [
                "保留备份日志个数"
            ],
            "default_check": true,
            "description": "清理多余的日志,节省空间"
        },
        {
            "name": "创意庭院（不要开启）",
            "entry": "创意庭院_前置检查"
        },
        {
            "name": "dbug（不要开启）",
            "entry": "关闭广告通用"
        }
    ],
    "option": {
        "存档覆盖进度": {
            "type": "select",
            "cases": [
                {
                    "name": "云端进度"
                },
                {
                    "name": "本地进度",
                    "pipeline_override": {
                        "开始游戏": {
                            "focus": "点击开始游戏",
                            "next": [
                                "开始游戏",
                                "使用本地进度",
                                "关闭公告"
                            ]
                        },
                    }
                }
            ]
        },
        "双倍碎片（需要免广告卡）": {
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "点击探险完成": {
                            "next": [
                                "植物探险_使用免广告卡",
                                "完成探险"
                            ]
                        },
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "每日免费五十钻": {
            "type": "switch",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "免广告卡_免费每日50钻": {
                            "enabled": true,
                        }
                    }
                }
            ]
        },
        "潘妮秘宝": {
            "type": "switch",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "option": [
                        "潘妮秘宝选择宝箱",
                        "潘妮秘宝使用几次免广告卡"
                    ],
                    "pipeline_override": {
                        "免广告卡_潘妮秘宝": {
                            "enabled": true,
                        }
                    }
                }
            ]
        },
        "潘妮秘宝选择宝箱": {
            "type": "select",
            "cases": [
                {
                    "name": "普通宝箱"
                },
                {
                    "name": "装扮碎片宝箱",
                    "pipeline_override": {
                        "潘妮秘宝_免广告卡_点击秘宝": {
                            "next": [
                                "潘妮秘宝_免广告卡_装扮宝物_滑动"
                            ]
                        },
                    }
                }
            ]
        },
        "潘妮秘宝使用几次免广告卡": {
            "type": "input",
            "inputs": [
                {
                    "name": "使用次数",
                    "pipeline_type": "int",
                    "default": "1",
                    "verify": "^[1-9]\\d{0,1}$"
                }
            ],
            "pipeline_override": {
                "免广告卡_潘妮秘宝": {
                    "max_hit": "{使用次数}",
                },
            }
        },
        "超z钥匙": {
            "type": "switch",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "免广告卡_超z钥匙": {
                            "enabled": true,
                        }
                    }
                }
            ]
        },
        "渠道服": {
            "type": "select",
            "description": "选择你要进入的渠道服",
            "cases": [
                {
                    "name": "联想",
                    "pipeline_override": {
                        "选择渠道服": {
                            "next": [
                                "关闭pvz_联想",
                                "打开pvz_联想"
