        "额外弹窗直接关闭": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "突发情况处理": {
                            "next": [
                                "识别第5回合",
                                "识别第6及以上回合",
                                "识别第7回合",
                                "游戏胜利",
                                "游戏失败",
                                "重开",
                                "识别成功，启动！",
                                "放一号位僵尸",
                                "突发情况处理"
                            ]
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "匹配模式": {
            "type": "select",
            "default_case": "不停止",
            "cases": [
                {
                    "name": "不停止"
                },
                {
                    "name": "到达大师锅后停止",
                    "pipeline_override": {
                        "检查是否到宗师锅": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "胜利十把后停止",
                    "pipeline_override": {
                        "重开": {
                            "enabled": false
                        },
                        "只重开十次": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "配置模式": {
            "type": "select",
            "default_case": "帮选模式",
            "cases": [
                {
                    "description": "启用该选项，会直接开始游戏",
                    "name": "自选植物模式",
                    "pipeline_override": {
                        "双人对决_竞技": {
