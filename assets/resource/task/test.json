{
    "option": {
        "保留备份日志个数": {
            "description": "清理日志时保留备份日志个数",
            "type": "input",
            "inputs": [
                {
                    "name": "保留日志数",
                    "label": "保留日志数",
                    "description": "输入需要的保留日志数,最大999",
                    "pipeline_type": "int",
                    "default": "3",
                    "verify": "^[1-9]\\d{0,2}$"
                }
            ],
            "pipeline_override": {
                "cleanup_maafw_bak_logs": {
                    "custom_action_param": {
                        "save_log_count": "{保留日志数}"
                    }
                }
            }
        },
    }
}