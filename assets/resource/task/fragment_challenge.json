        "使用免广告卡": {
            "type": "switch",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "option": [
                        "双倍植物碎片",
                        "增加巨人危机挑战次数",
                        "增加邪恶入侵挑战次数"
                    ],
                    "pipeline_override": {
                        "碎片挑战_重置所有偏移": {
                            "next": [
                                "点击日常_增加挑战次数_点击日常",
                                "[JumpBack]检查当前是否在主界面"
                            ]
                        }
                    },
                }
            ]
        },
        "双倍植物碎片": {
            "type": "switch",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "碎片挑战_钱袋子": {
                            "next": [
                                "碎片挑战_完成对局_确定_免广告卡",
                                "碎片挑战_完成对局__确定",
                                "碎片挑战_钱袋子"
                            ]
                        },
                    }
                },
            ]
        },
        "增加巨人危机挑战次数": {
            "type": "switch",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "点击日常_增加挑战次数_增加巨人危机次数": {
                            "enabled": true,
                        }
                    }
                },
            ]
        },
        "增加邪恶入侵挑战次数": {
            "type": "switch",
