{
    // ======================== 点击并计数节点 ========================
    // 参数（均在 custom_action_param 中）：
    //   template  : 模板图片路径（必需）
    //   name      : 植物名称（必需）
    //   level     : 点击阶数（1~4），可选，默认使用当前阶数
    //   threshold : 模板匹配阈值（0~1），可选，默认 0.7
    //   roi       : 限定识别区域 [x, y, w, h]，可选
    //   delay     : 每次点击后等待毫秒数（含最后一次），可选，默认 0
    //   repeat    : 不填则自动递增（第1次点1下，第2次点2下…），填数字则固定次数
    "点击一阶": {
        "action": "Custom",
        "custom_action": "ClickAndCount",
        "custom_action_param": {
            "template": "神器一阶.png",
            "name": "进化神器序列",
            "level": 1,
            "roi": [
                630,
                345,
                65,
                72
            ],
            "delay": 2000 // 统一间隔 2 秒
        },
        "next": [
            "点击二阶",
            "点击三阶",
            "点击四阶"
        ]
    },
    "点击二阶": {
        "action": "Custom",
        "custom_action": "ClickAndCount",
        "custom_action_param": {
            "template": "神器二阶.png",
            "name": "进化神器序列",
            "level": 2,
            "roi": [
                695,
                349,
                60,
                64
            ],
            "delay": 2000
        },
        "next": [
            "点击三阶",
            "点击四阶"
        ]
    },
    "点击三阶": {
        "action": "Custom",
        "custom_action": "ClickAndCount",
        "custom_action_param": {
            "template": "神器三阶.png",
            "name": "进化神器序列",
            "level": 3,
            "roi": [
                755,
                352,
                60,
                63
            ],
            "delay": 2000
        },
        "next": [
            "点击四阶"
        ]
    },
    "点击四阶": {
        "action": "Custom",
        "custom_action": "ClickAndCount",
        "custom_action_param": {
            "template": "神器四阶.png",
            "name": "进化神器序列",
            "level": 4,
            "threshold": 0.9,
            "roi": [
                818,
                350,
                61,
                63
            ],
            "delay": 2000
        },
        "next": [
            "点击一阶"
        ] // 保持循环
    },
    // ======================== 截图保存节点 ========================
    // 路径：screenshots/植物名称/一阶X次_二阶X次_三阶X次_四阶X次.png
    "截图保存": {
        "action": "Custom",
        "custom_action": "TakeCountScreenshot",
        "custom_action_param": {
            "name": "进化神器序列"
        }
    },
    // ======================== 重置计数器节点 ========================
    // 清空所有点击次数及运行次数，下次从第1次开始递增
    "重置": {
        "action": "Custom",
        "custom_action": "ResetPlantCount"
    }
}