{
    "json.schemas": [
        {
            "fileMatch": [
                "/assets/resource/pipeline/**/*.json",
                "/install/resource/pipeline/**/*.json",
                "/assets/resource/pipeline/**/*.jsonc",
                "/install/resource/pipeline/**/*.jsonc"
            ],
            "url": "/deps/tools/pipeline.schema.json"
        },
        {
            "fileMatch": [
                "/assets/interface.json",
                "/install/interface.json",
                "/assets/resource/task/**/*.json",
                "/install/resource/task/**/*.json",
                "/assets/resource/task/**/*.jsonc",
                "/install/resource/task/**/*.jsonc"
            ],
            "url": "/deps/tools/interface.schema.json"
        },
        {
            "fileMatch": [
                "/install/config/maa_pi_config.json"
            ],
            "url": "/deps/tools/interface_config.schema.json"
        }
    ],
    "files.associations": {
        "**/assets/**/*.json": "jsonc"
    },
    "[json][jsonc]": {
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.tabSize": 4,
        "editor.indentSize": "tabSize"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "[markdown]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "Codegeex.RepoIndex": true
}